# Copy to .env and fill in real values. Never commit .env.
# All values are read from the environment at startup (see Config::from_env).

# HTTP listen port.
PORT=8080

# When set, protected routes require a matching X-API-Key header.
# Leave unset to disable API-key auth (not recommended for production).
API_KEY=

# CockroachDB connection settings.
COCKROACH_HOST=your-cluster.cockroachlabs.cloud
COCKROACH_PORT=26257
COCKROACH_USER=your_db_user
# Required for live database access. Supply via a secret manager in production.
COCKROACH_PASSWORD=
# TLS mode: "require" (default) or "disable" (local development only).
COCKROACH_SSL=require
